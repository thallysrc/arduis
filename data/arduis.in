#!/usr/bin/env python3
"""arduis launcher (installed).

Imports the INSTALLED ``arduis`` package from the Python purelib and runs its
entry point. Unlike the dev shim ``src/main.py``, this launcher carries NO
``sys.path`` manipulation: meson installs the ``arduis`` package into
site-packages, so ``import arduis`` resolves natively (and
``importlib.resources`` finds the packaged Claude Code hook).

Version: @VERSION@
"""
import sys

if "--version" in sys.argv[1:]:
    print("arduis @VERSION@")
    raise SystemExit(0)

from arduis.main import main

raise SystemExit(main())
